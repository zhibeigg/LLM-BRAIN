{
  "productName": "LLM-BRAIN",
  "version": "0.1.0",
  "identifier": "com.llm-brain.app",
  "build": {
    "beforeDevCommand": "cd frontend && bun run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "cd frontend && bun run build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LLM-BRAIN - 有向记忆图智能体系统",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "有向记忆图 + 多角色 LLM 类脑智能体系统",
    "longDescription": "LLM-BRAIN 用有向图模拟大脑的记忆网络，每个节点是一个知识/记忆片段，边代表知识间的依赖关系。系统通过性格参数影响路径选择，让同一张图谱在不同性格下表现出不同的推理行为。",
    "copyright": "Copyright © 2025 LLM-BRAIN",
    "category": "DeveloperTool",
    "windows": {
      "wix": null,
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": true,
        "languages": ["SimpChinese", "English"]
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "dialog": {
      "open": true
    }
  }
}
